{
  "name": "payroll",
  "version": "0.0.0",
  "scripts": {
    "build": "shx rm -rf dist && tsc --project tsconfig.prod.json && npm run build:copy-static",
    "build:copy-static": "shx mkdir -p dist/public dist/views && shx cp -r src/public/* dist/public && shx cp -r src/views/* dist/views",
    "build:make-db": "shx mkdir -p dist/repos/common && shx touch dist/repos/common/database.json && echo \"{}\" > dist/repos/common/database.json",
    "clean-install": "rm -rf ./node_modules && rm -r package-lock.json && npm i",
    "dev:basic": "cross-env DOTENV_CONFIG_PATH=./config/.env.development ts-node ./src/main",
    "dev:watch": "nodemon --exec \"npm run dev:basic\" --watch ./src --ext .ts",
    "dev": "concurrently \"npm run dev:watch\" \"npm run sync\"",
    "lint": "eslint .",
    "format": "prettier --write .",
    "start": "cross-env DOTENV_CONFIG_PATH=./config/.env.production node -r dotenv/config -r module-alias/register ./dist/src/main.js",
    "sync": "delay 1s && browser-sync start --config bs-config.js",
    "test": "cross-env NODE_ENV=test vitest",
    "type-check": "tsc -b --noEmit",
    "db:migrate:up": "sequelize-cli db:migrate",
    "db:migrate:down": "sequelize-cli db:migrate:undo",
    "db:migrate:down:all": "sequelize-cli db:migrate:undo:all",
    "db:migrate:status": "sequelize-cli db:migrate:status",
    "db:migration:new": "sequelize-cli migration:generate --name",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:undo": "sequelize-cli db:seed:undo:all"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "_moduleAliases": {
    "@src": "dist/src"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "jet-env": "^1.1.6",
    "jet-logger": "^2.2.3",
    "jet-paths": "^3.1.1",
    "jet-validators": "^2.3.1",
    "joi": "^18.2.3",
    "jsonfile": "^6.2.1",
    "module-alias": "^2.3.4",
    "morgan": "^1.11.0",
    "pg": "^8.22.0",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.5",
    "tspo": "^1.0.7",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@swc/core": "^1.15.43",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/find": "^0.2.4",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonfile": "^6.1.4",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.0",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.3",
    "delay-cli": "^3.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^18.2.1",
    "find": "^0.3.0",
    "fs-extra": "^11.3.6",
    "jiti": "^2.7.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "shx": "^0.4.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
